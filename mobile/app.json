{
  "expo": {
    "name": "Troca",
    "slug": "troca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "troca",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nc.troca.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:troca.nc"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Troca utilise votre caméra pour prendre des photos de vos annonces.",
        "NSPhotoLibraryUsageDescription": "Troca accède à vos photos pour illustrer vos annonces.",
        "NSLocationWhenInUseUsageDescription": "Troca utilise votre position pour afficher les annonces proches.",
        "NSUserNotificationsUsageDescription": "Troca vous envoie des notifications pour vos messages et annonces.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "nc.troca.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "troca.nc",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#2563eb",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Troca accède à vos photos pour illustrer vos annonces."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.nc.troca.app",
          "enableGooglePay": true
        }
      ],
      "expo-apple-authentication",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "CHANGEME_eas_project_id"
      }
    },
    "owner": "CHANGEME_expo_account"
  }
}
