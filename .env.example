# Troca - sanitized environment example
NODE_ENV=production
BASE_URL=https://example.com
DOMAIN=example.com
DEPLOY_PATH=/opt/troca
REPO_URL=https://github.com/your-org/troca.git
NEXT_PUBLIC_API_URL=https://example.com/api
EXPO_PUBLIC_API_URL=https://example.com/api
NEXT_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_DEMO_MODE=false
DEMO_MODE=false
RUN_JOBS=true
# Admin dashboard isolated
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$change-me-change-me-change-me-change-me-change-me
ADMIN_TOTP_SECRET=base32secretchangeme
ADMIN_API_TOKEN=uuid-v4-long-random-token-change-me
ADMIN_ALERT_EMAIL=admin@example.com
NEXTAUTH_SECRET=change-me-32-chars-minimum
NEXTAUTH_URL=https://admin.troca.nc
# Bons Plans: flush Redis view counters into PostgreSQL toutes les heures.
BON_PLAN_VIEWS_FLUSH_INTERVAL_MS=3600000
# Troc — matching worker and expiry guards.
TROC_MATCHING_ENABLED=true
TROC_PROPOSAL_EXPIRY_DAYS=7
TROC_CYCLE_EXPIRY_HOURS=48
TROC_CYCLE_MAX_DEPTH=3
PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=troca
DB_USER=troca
DB_PASSWORD=change-me
DB_POOL_MAX=10
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
JWT_SECRET=change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
INTERNAL_API_TOKEN=change-me
MAX_FILE_SIZE_MB=10
MAX_IMAGES_PER_LISTING=8
STORAGE_LOCAL_PATH=/app/uploads
GOOGLE_CLIENT_ID=change-me
NEXT_PUBLIC_GOOGLE_CLIENT_ID=change-me
EXPO_PUBLIC_GOOGLE_CLIENT_ID=change-me
TURNSTILE_SECRET_KEY=change-me
NEXT_PUBLIC_TURNSTILE_SITE_KEY=change-me
NEXT_PUBLIC_STRIPE_PK=change-me
STRIPE_SECRET_KEY=change-me
STRIPE_WEBHOOK_SECRET=change-me
STRIPE_PRICE_PRO_MENSUEL=change-me
STRIPE_PRICE_PRO_ANNUEL=change-me
# DEPRECATED — plan supprimé v2
# STRIPE_PRICE_PRO_PLUS_MENSUEL=change-me
# STRIPE_PRICE_PRO_PLUS_ANNUEL=change-me
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=change-me
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=change-me
# DEPRECATED — plan supprimé v2
# NEXT_PUBLIC_STRIPE_PRICE_PRO_PLUS_MONTHLY=change-me
# NEXT_PUBLIC_STRIPE_PRICE_PRO_PLUS_YEARLY=change-me
PAYPLUG_SECRET_KEY=change-me
PAYPLUG_PUBLIC_KEY=change-me
PAYPLUG_WEBHOOK_SECRET=change-me
NEXT_PUBLIC_PAYPLUG_PLAN_PRO_MONTHLY=change-me
NEXT_PUBLIC_PAYPLUG_PLAN_PRO_YEARLY=change-me
# DEPRECATED — plan supprimé v2
# NEXT_PUBLIC_PAYPLUG_PLAN_PRO_PLUS_MONTHLY=change-me
# NEXT_PUBLIC_PAYPLUG_PLAN_PRO_PLUS_YEARLY=change-me
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change-me
SMTP_FROM=noreply@example.com
TWILIO_ACCOUNT_SID=change-me
TWILIO_AUTH_TOKEN=change-me
TWILIO_VERIFY_SID=change-me
APPLE_CLIENT_ID=change-me
APPLE_TEAM_ID=change-me
APPLE_KEY_ID=change-me
APPLE_PRIVATE_KEY=change-me
EXPO_PUBLIC_PROJECT_ID=change-me
EXPO_ACCESS_TOKEN=change-me
AWS_REGION=ap-southeast-2
AWS_BUCKET=change-me
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
SERVER_HOST=change-me
SERVER_USER=change-me
SERVER_SSH_KEY=change-me
# Use admin only after strong authentication and restricted access.
OBSERVABILITY_ROLE=viewer
NEXT_STANDALONE=1
